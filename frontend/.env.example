# =============================================================
# MegaFish Frontend Configuration
# =============================================================
# Copy this file to .env.local and adjust values as needed.
# All variables must be prefixed with VITE_ to be exposed to
# the browser bundle (Vite convention).
# =============================================================

# Backend API base URL
# Default: http://localhost:5001
# In Docker: set to http://localhost:5001 (ports are forwarded)
# In production: set to your deployed backend URL
VITE_API_BASE_URL=http://localhost:5001
